# OpenAI (required for AI chat)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Lightning Backend: lnd | swissknife | mock (default: mock)
BACKEND_TYPE=mock

# === LND ===
# LND REST API URL (e.g. https://umbrel.local:8080)
# LND_URL=https://localhost:8080
# Hex-encoded macaroon (use a budget-limited one, see README)
# LND_MACAROON=0201036c6e64...
# Uncomment if LND uses self-signed TLS cert:
# NODE_TLS_REJECT_UNAUTHORIZED=0

# === SwissKnife ===
# SWISSKNIFE_URL=https://app.numeraire.tech
# SWISSKNIFE_API_KEY=your_api_key

# Satring API (optional, defaults to https://satring.com/api/v1)
# SATRING_API_URL=https://satring.com/api/v1
