# Required: OpenAI API key
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Model selection (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: Lightning backend (default: mock)
# BOLT402_BACKEND=mock
# BOLT402_BACKEND=lnd
# BOLT402_BACKEND=swissknife

# LND backend configuration
# BOLT402_LND_URL=https://localhost:8080
# BOLT402_LND_MACAROON=hex-encoded-admin-macaroon

# SwissKnife backend configuration
# BOLT402_SWISSKNIFE_URL=https://app.numeraire.tech
# BOLT402_SWISSKNIFE_API_KEY=your-api-key

# Optional: Budget limits (in satoshis)
# BOLT402_BUDGET_PER_REQUEST=1000
# BOLT402_BUDGET_TOTAL=100000
